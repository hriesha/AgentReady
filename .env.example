# Copy this file to .env and fill in the values. Never commit .env.

# LLM provider settings. Create a free API key at https://aistudio.google.com
# with a Google account. The Gemini API free tier needs no credit card and no
# billing account. Do not enable billing on the Google Cloud project behind
# the key, that is what keeps it free.
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash
# Client-side throttle for outbound LLM calls, kept safely under the free
# tier limit of 15 requests per minute.
LLM_MAX_RPM=12

DATABASE_URL=sqlite:///./agentready.db
WEB_ORIGIN=http://localhost:5173

# When true, the app serves a precomputed audit of the bundled sample catalog
# and makes zero live LLM calls.
DEMO_MODE=false
